{
    "tasks": [
        {
            "type": "cppbuild",
            "label": "C/C++: build labo2",
            "command": "/usr/bin/gcc",
            "args": [
                "-fdiagnostics-color=always",
                "-g",
                "${workspaceFolder}/labo2/src/main.c",
                "${workspaceFolder}/labo2/src/area.c",
                "${workspaceFolder}/labo2/src/aritmetica.c",
                "-I${workspaceFolder}/labo2/include",
                "-o",
                "${workspaceFolder}/labo2/labo2_app"
            ],
            "options": {
                "cwd": "${workspaceFolder}/labo2"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "Task generated by Debugger."
        }
    ],
    "version": "2.0.0"
}